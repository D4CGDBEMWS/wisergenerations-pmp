# =============================================================================
# Wiser Generations Int'l™ — Environment variables
# =============================================================================
# Copy this file to `.env.local` for local development, and mirror every
# variable in Vercel → Project Settings → Environment Variables for
# Production, Preview, and Development.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser and bundled
# into client JavaScript. Everything else is server-only.
# =============================================================================


# -----------------------------------------------------------------------------
# Stripe — payments and subscriptions
# -----------------------------------------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
#   • Use sk_test_… / pk_test_… in Preview & Development
#   • Use sk_live_… / pk_live_… in Production
# Test-mode keys cannot read live-mode prices and vice versa — keep them
# consistent within each Vercel environment.

STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Stripe webhook signing secret for /api/stripe/webhook
# Create a webhook endpoint at https://dashboard.stripe.com/webhooks
# pointed at https://wisergenerations.com/api/stripe/webhook and copy
# the "Signing secret" (starts with whsec_…)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Recurring Price ID for the $47/month "Wiser Generations Int'l™ Study Access"
# (the Community of Practice product). Find it under
# Stripe Dashboard → Products → Community of Practice → Pricing.
# Must match the mode (test vs. live) of the keys above.
NEXT_PUBLIC_STRIPE_STUDY_PRICE_ID=price_replace_me


# -----------------------------------------------------------------------------
# Mailchimp — newsletter & enrollment list
# -----------------------------------------------------------------------------
# Used by /api/subscribe (newsletter signup, also tagged for segmentation)
# and the Stripe webhook to add purchasers to Mailchimp.
# API key format: <key>-<datacenter>, e.g. abc123-us21
MAILCHIMP_API_KEY=replace_me-us21
MAILCHIMP_AUDIENCE_ID=replace_me


# -----------------------------------------------------------------------------
# ConvertKit — Free Guide lead magnet
# -----------------------------------------------------------------------------
# Used by /api/free-guide to deliver the "PMP® Exam Changes 2026" PDF.
# https://app.convertkit.com/account_settings/advanced_settings
CONVERTKIT_API_KEY=replace_me
CONVERT_KIT_FORM_ID=replace_me
